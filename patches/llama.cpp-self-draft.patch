+// find a Multi-Token-Prediction draft sibling next to a local model file, e.g.
+// "mtp-<name>.gguf" or "<name>-MTP.gguf". Lets --self-draft work fully offline.
+static std::string common_find_local_mtp_sibling(const std::string & model_path) {
+    if (model_path.empty()) {
+        return "";
+    }
+    std::error_code ec;
+    std::filesystem::path dir = std::filesystem::path(model_path).parent_path();
+    if (dir.empty()) {
+        dir = std::filesystem::current_path(ec);
+    }
+    if (!std::filesystem::is_directory(dir, ec)) {
+        return "";
+    }
+    std::string best;
+    for (const auto & entry : std::filesystem::directory_iterator(dir, ec)) {
+        if (ec) {
+            break;
+        }
+        if (!entry.is_regular_file(ec)) {
+            continue;
+        }
+        const std::string fn = entry.path().filename().string();
+        if (fn.size() < 6 || fn.substr(fn.size() - 5) != ".gguf") {
+            continue;
+        }
+        if (fn.rfind("mtp-", 0) == 0 || fn.find("-MTP.") != std::string::npos) {
+            // prefer the shortest name: the dedicated head, not a full *-MTP model
+            if (best.empty() || fn.size() < std::filesystem::path(best).filename().string().size()) {
+                best = entry.path().string();
+            }
+        }
+    }
+    return best;
+}
